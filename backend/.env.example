# --- NeonDB ---
# Pooled connection string (used by the app at runtime).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# Direct (unpooled) connection string (used by Prisma for migrations).
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DB?sslmode=require"

# --- Server ---
PORT=3001
# Comma-separated origins allowed by CORS. Frontend dev runs on :3000 (Next).
# In production add the deployed frontend Railway URL, e.g. https://<frontend>.up.railway.app
CORS_ORIGIN=http://localhost:3000

# --- Firebase Admin (Google SSO token verification) ---
# Service account credentials used by firebase-admin to verify the ID tokens
# minted by Google sign-in on the frontend. Get these from the Firebase console:
# Project settings > Service accounts > Generate new private key.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
# Keep the literal \n escapes; the app converts them back to newlines at load.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# --- OpenAI (AI capability) ---
OPENAI_API_KEY=sk-...
# Optional: override the default model.
# OPENAI_MODEL=gpt-4o-mini

# --- Email (Invitation) ---
# Dev: Gmail SMTP (requires a Gmail App Password, not your regular password)
# To create an App Password: Google Account > Security > 2-Step Verification > App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=your-email@gmail.com

# Prod: Resend API
RESEND_API_KEY=re_xxxx
NODE_ENV=development
