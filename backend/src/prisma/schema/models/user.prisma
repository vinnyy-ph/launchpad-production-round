/// Auth-level user — owns login credentials and role
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  googleId  String?  @unique
  role      Role     @default(EMPLOYEE)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee?

  // ── Audit ──
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  deletedBy String?

  @@map("users")
}
