model OnboardingDocument {
  id               String             @id @default(uuid())
  templateId       String
  template         OnboardingTemplate @relation(fields: [templateId], references: [id])
  documentName     String
  instructions     String?
  allowedFileTypes String // e.g. "pdf,jpg,png"
  isRequired       Boolean            @default(true)
  createdAt        DateTime           @default(now())

  submissions OnboardingDocumentSubmission[]

  // ── Audit ──
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?
  deletedAt DateTime?
  deletedBy String?

  @@map("onboarding_documents")
}
