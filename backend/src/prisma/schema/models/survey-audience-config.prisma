/// Defines which supervisors/teams a survey targets (when not EVERYONE)
model SurveyAudienceConfig {
  id           String       @id @default(uuid())
  surveyId     String
  survey       PulseSurvey  @relation(fields: [surveyId], references: [id])
  supervisorId String?
  teamId       String?
  team         Team?        @relation(fields: [teamId], references: [id])
  createdAt    DateTime     @default(now())
  createdBy    String?
  updatedAt    DateTime     @updatedAt
  updatedBy    String?
  deletedAt    DateTime?
  deletedBy    String?

  @@map("survey_audience_configs")
}
