/// Defines which supervisors/teams a survey targets (when not EVERYONE)
model SurveyAudienceConfig {
  id           String      @id @default(uuid())
  surveyId     String
  supervisorId String?
  teamId       String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  supervisor   Employee?   @relation(fields: [supervisorId], references: [id])
  survey       PulseSurvey @relation(fields: [surveyId], references: [id])
  team         Team?       @relation(fields: [teamId], references: [id])

  @@map("survey_audience_configs")
}
