model OffboardingRecord {
  id                  String                      @id @default(uuid())
  employeeId          String                      @unique
  clearanceTemplateId String
  initiatedById       String
  tenderDate          DateTime
  effectiveDate       DateTime
  attachmentUrl       String?
  status              OffboardingStatus           @default(IN_PROGRESS)
  createdAt           DateTime                    @default(now())
  completedAt         DateTime?
  updatedAt           DateTime                    @updatedAt
  signatureRequests   ClearanceSignatureRequest[]
  clearanceTemplate   ClearanceTemplate           @relation(fields: [clearanceTemplateId], references: [id])
  employee            Employee                    @relation("OffboardingSubject", fields: [employeeId], references: [id])
  initiatedBy         Employee                    @relation("OffboardingInitiator", fields: [initiatedById], references: [id])

  @@map("offboarding_records")
}
