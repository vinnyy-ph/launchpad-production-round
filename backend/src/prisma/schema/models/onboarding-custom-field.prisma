model OnboardingCustomField {
  id         String             @id @default(uuid())
  templateId String
  template   OnboardingTemplate @relation(fields: [templateId], references: [id])
  fieldLabel String
  isRequired Boolean            @default(false)
  createdAt  DateTime           @default(now())

  values OnboardingCustomFieldValue[]

  // ── Audit ──
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?
  deletedAt DateTime?
  deletedBy String?

  @@map("onboarding_custom_fields")
}
