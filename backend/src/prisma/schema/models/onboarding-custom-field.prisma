model OnboardingCustomField {
  id         String             @id @default(uuid())
  templateId String
  template   OnboardingTemplate @relation(fields: [templateId], references: [id])
  fieldLabel String
  isRequired Boolean            @default(false)
  createdAt  DateTime           @default(now())
  createdBy  String?
  updatedAt  DateTime           @updatedAt
  updatedBy  String?
  deletedAt  DateTime?
  deletedBy  String?

  values OnboardingCustomFieldValue[]

  @@map("onboarding_custom_fields")
}
