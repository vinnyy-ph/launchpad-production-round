/// Per-occurrence audience snapshot. Recurrence re-evaluates the audience at
/// each release and freezes the resolved members here, so reminders and
/// minimum-group-size counts use the audience as it was when the occurrence opened.
model SurveyAudienceMember {
  occurrenceId String
  occurrence   SurveyOccurrence @relation(fields: [occurrenceId], references: [id])
  employeeId   String
  employee     Employee         @relation(fields: [employeeId], references: [id])

  @@id([occurrenceId, employeeId])
  @@map("survey_audience_members")
}
