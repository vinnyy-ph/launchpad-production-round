model ActivityLog {
  id               String   @id @default(uuid())
  editorId         String
  editor           Employee @relation("Editor", fields: [editorId], references: [id])
  targetEmployeeId String
  targetEmployee   Employee @relation("Target", fields: [targetEmployeeId], references: [id])
  fieldName        String
  oldValue         String?
  newValue         String?
  timestamp        DateTime @default(now())
  createdAt        DateTime @default(now())
  createdBy        String?
  updatedAt        DateTime @updatedAt
  updatedBy        String?
  deletedAt        DateTime?
  deletedBy        String?

  @@map("activity_logs")
}
