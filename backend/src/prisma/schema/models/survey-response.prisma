model SurveyResponse {
  id                     String           @id @default(uuid())
  occurrenceId           String
  /// Null when survey is anonymous
  employeeId             String?
  /// Anonymity-safe grouping snapshots — populated even when anonymous so
  /// results can be filtered by supervisor/team without re-identifying anyone.
  respondentSupervisorId String?
  respondentTeamIds      String[]
  submittedAt            DateTime         @default(now())
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  answers                SurveyAnswer[]
  employee               Employee?        @relation(fields: [employeeId], references: [id])
  occurrence             SurveyOccurrence @relation(fields: [occurrenceId], references: [id])

  @@map("survey_responses")
}
