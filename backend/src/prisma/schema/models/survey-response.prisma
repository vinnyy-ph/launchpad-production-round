model SurveyResponse {
  id                     String           @id @default(uuid())
  occurrenceId           String
  /// Null when survey is anonymous
  employeeId             String?
  /// Anonymity-safe grouping snapshots — populated even when anonymous so
  /// results can be filtered by supervisor/team without re-identifying anyone.
  respondentSupervisorId String?
  respondentTeamIds      String[]
  submittedAt            DateTime         @default(now())
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  answers                SurveyAnswer[]
  employee               Employee?        @relation(fields: [employeeId], references: [id])
  occurrence             SurveyOccurrence @relation(fields: [occurrenceId], references: [id])
  /// Back-relation for the author's self-view link (SurveyCompletion.responseId). The author
  /// is recovered through their completion, never through this response's null employeeId.
  completion             SurveyCompletion?

  @@map("survey_responses")
}
