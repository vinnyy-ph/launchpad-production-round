model Team {
  id        String   @id @default(uuid())
  name      String
  leaderId  String
  leader    Employee @relation("TeamLeader", fields: [leaderId], references: [id])
  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?
  deletedAt DateTime?
  deletedBy String?

  members              TeamMember[]
  surveyAudienceConfig SurveyAudienceConfig[]

  @@map("teams")
}
