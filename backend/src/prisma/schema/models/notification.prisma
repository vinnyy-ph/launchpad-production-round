model Notification {
  id          String           @id @default(uuid())
  recipientId String
  recipient   Employee         @relation(fields: [recipientId], references: [id])
  type        NotificationType
  subject     String
  body        String
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  createdBy   String?
  updatedAt   DateTime         @updatedAt
  updatedBy   String?
  deletedAt   DateTime?
  deletedBy   String?

  @@map("notifications")
}
