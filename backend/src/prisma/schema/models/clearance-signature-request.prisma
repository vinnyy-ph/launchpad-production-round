model ClearanceSignatureRequest {
  id              String           @id @default(uuid())
  offboardingId   String
  offboarding     OffboardingRecord @relation(fields: [offboardingId], references: [id])
  signatoryId     String
  signatory       Employee          @relation(fields: [signatoryId], references: [id])
  status          SignatoryStatus   @default(PENDING)
  note            String?
  actionAt        DateTime?
  createdAt       DateTime          @default(now())
  createdBy       String?
  updatedAt       DateTime          @updatedAt
  updatedBy       String?
  deletedAt       DateTime?
  deletedBy       String?

  @@unique([offboardingId, signatoryId])
  @@map("clearance_signature_requests")
}
