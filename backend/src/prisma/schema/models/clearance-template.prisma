model ClearanceTemplate {
  id        String   @id @default(uuid())
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?
  deletedAt DateTime?
  deletedBy String?

  signatories       ClearanceSignatory[]
  offboardingRecord OffboardingRecord[]

  @@map("clearance_templates")
}
