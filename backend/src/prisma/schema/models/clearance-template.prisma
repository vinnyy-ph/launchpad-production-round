model ClearanceTemplate {
  id        String   @id @default(uuid())
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  signatories       ClearanceSignatory[]
  offboardingRecord OffboardingRecord[]

  // ── Audit ──
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?
  deletedAt DateTime?
  deletedBy String?

  @@map("clearance_templates")
}
