model BulkOnboardingJob {
  id           String        @id @default(uuid())
  initiatedBy  String
  fileUrl      String
  totalRows    Int           @default(0)
  successCount Int           @default(0)
  failureCount Int           @default(0)
  status       BulkJobStatus @default(PROCESSING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  initiator    Employee      @relation(fields: [initiatedBy], references: [id])

  @@map("bulk_onboarding_jobs")
}
