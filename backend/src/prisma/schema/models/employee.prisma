/// HR/People data for a user
model Employee {
  id                         String                         @id @default(uuid())
  userId                     String                         @unique
  companyEmail               String                         @unique
  firstName                  String
  lastName                   String
  middleName                 String?
  personalEmail              String?
  birthday                   DateTime?
  jobTitle                   String?
  departmentId               String?
  /// Self-referential supervisor tree
  supervisorId               String?
  status                     EmployeeStatus                 @default(ONBOARDING)
  createdAt                  DateTime                       @default(now())
  updatedAt                  DateTime                       @updatedAt
  editsPerformed             ActivityLog[]                  @relation("Editor")
  editsReceived              ActivityLog[]                  @relation("Target")
  bulkOnboardingJobs         BulkOnboardingJob[]
  clearanceSignatories       ClearanceSignatory[]
  clearanceSignatures        ClearanceSignatureRequest[]
  address                    EmployeeAddress?
  emergencyContact           EmployeeEmergencyContact?
  notificationPreference     NotificationPreference?
  department                 Department?                    @relation(fields: [departmentId], references: [id])
  supervisor                 Employee?                      @relation("SupervisorTree", fields: [supervisorId], references: [id])
  directReports              Employee[]                     @relation("SupervisorTree")
  user                       User                           @relation(fields: [userId], references: [id])
  evaluationAcknowledgements EvaluationAcknowledgement[]
  notifications              Notification[]
  offboardingRecord          OffboardingRecord?             @relation("OffboardingSubject")
  offboardingsInitiated      OffboardingRecord[]            @relation("OffboardingInitiator")
  reviewedDocuments          OnboardingDocumentSubmission[]
  onboardingRecord           OnboardingRecord?
  evaluationsReceived        PerformanceEvaluation[]        @relation("Reviewee")
  evaluationsGiven           PerformanceEvaluation[]        @relation("Reviewer")
  surveysCreated             PulseSurvey[]
  surveyAudienceTargets      SurveyAudienceConfig[]
  surveyAudienceMemberships  SurveyAudienceMember[]
  surveyCompletions          SurveyCompletion[]
  surveyResponses            SurveyResponse[]
  surveyResultsShared        SurveyResultShare[]            @relation("SurveyResultShareSharedBy")
  surveyResultsReceived      SurveyResultShare[]            @relation("SurveyResultShareSupervisor")
  teamMemberships            TeamMember[]
  ledTeams                   Team[]                         @relation("TeamLeader")

  @@map("employees")
}

/// Structured home address associated with one employee profile.
model EmployeeAddress {
  id         String   @id @default(uuid())
  employeeId String   @unique
  address    String?
  city       String?
  province   String?
  country    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_addresses")
}

/// Emergency contact details associated with one employee profile.
model EmployeeEmergencyContact {
  id                     String   @id @default(uuid())
  employeeId             String   @unique
  emergencyContactName   String?
  emergencyContactNumber String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  employee               Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_emergency_contacts")
}
