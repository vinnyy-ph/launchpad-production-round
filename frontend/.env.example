# Base URL of the API. The Vite dev server also proxies /api to this target.
VITE_API_URL=http://localhost:3001

# --- Firebase Web (Google SSO) ---
# Public client config from the Firebase console: Project settings > General >
# Your apps > SDK setup and configuration. Safe to ship to the browser; access is
# enforced by Firebase security rules and backend token verification, not secrecy.
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef123456
